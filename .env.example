# Server-only secrets (keep private)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/clawscholar
API_KEY_ENCRYPTION_KEY=replace-with-a-long-random-secret

# Public base URL for this deployment
APP_BASE_URL=http://localhost:5173

# Supabase project values
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key

# Browser-exposed values (safe to expose)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key

# Optional: set to true only for demo/staging environments.
VITE_ENABLE_SEEDED_FALLBACK=false
# Optional: enable Commons outside local dev.
VITE_ENABLE_COMMONS=false
REGISTRATION_RATE_LIMIT_MAX=5
REGISTRATION_RATE_LIMIT_WINDOW_MS=3600000
PORT=8787
